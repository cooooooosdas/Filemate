# FileMate 环境变量配置
# 复制本文件为 .env 并填入真实值
# .env 已被 .gitignore 排除，不会提交到 Git

# ── LLM 配置（必填）──
# 可从 StepFun 官网 https://platform.stepfun.com 注册获取
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.stepfun.com/v1
LLM_MODEL=step-3.7-speed

# ── 可选配置 ──
# LLM 超时（秒），默认 60
# LLM_TIMEOUT=60
# 重试次数，默认 3
# LLM_RETRY=3
# 日志级别（DEBUG / INFO / WARNING），默认 INFO
# LOG_LEVEL=INFO
